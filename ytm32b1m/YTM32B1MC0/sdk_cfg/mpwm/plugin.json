{
    "name": "mpwm",
    "type": "driver",
    "srcs": [
        "App.vue",
        "Common.vue",
        "IC.vue",
        "CT.vue",
        "OC.vue",
        "PC.vue",
        "PWM.vue"
    ],
    "mode": "raw",
    "label": "MPWM",
    "includes": [
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_common.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_ic_driver.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_oc_driver.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_pc_driver.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_pwm_driver.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/mpwm_ct_driver.h"
    ],
    "args": [
        "MPWM_DRV_InitInputCapture {{#each this.data.ic.data}}(0,&{{this.name}});{{/each}}",
        "MPWM_DRV_InitOutputCompare {{#each this.data.oc.data}}(0,&{{this.name}});{{/each}}",
        "MPWM_DRV_InitPulseCounter {{#each this.data.pc.data}}(0,&{{this.name}});{{/each}}",
        "MPWM_DRV_InitPwm {{#each this.data.pwm.data}}(0,&{{this.name}});{{/each}}",
        "MPWM_DRV_InitTimer {{#each this.data.ct.data}}(0,&{{this.name}});{{/each}}",
        "MPWM_DRV_Init {{#each this.data.common}}(0,&{{this.state_name}});{{/each}}",
        "MPWM_DRV_SetClkSrc {{#each this.data.common}}(0,MPWM_BUS_CLOCK);{{/each}}"
    ],
    "forceEnable": false,
    "generate": [
        "mpwm_config.c",
        "mpwm_config.h"
    ],
    "move": [
        {
