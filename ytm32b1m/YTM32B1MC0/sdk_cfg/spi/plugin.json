{
    "name": "spi",
    "type": "driver",
    "mode": "raw",
    "srcs": [
        "App.vue"
    ],
    "label": "SPI",
    "depend": [
        "dma"
    ],
    "includes": [
        "./../../YTM32Bx_SDK/platform/drivers/inc/spi_master_driver.h",
        "./../../YTM32Bx_SDK/platform/drivers/inc/spi_slave_driver.h"
    ],
    "generate": [
        "spi_config.c",
        "spi_config.h"
    ],
    "args": [
        "SPI_DRV_MasterInit {{#each this.data.master}}(0,&{{this.name}}_State,&{{this.name}});{{/each}}",
        "SPI_DRV_SlaveInit {{#each this.data.slave}}(0,&{{this.name}}_State,&{{this.name}});{{/each}}"
    ],
    "move": [
        {
            "from": "./../../YTM32Bx_SDK/platform/drivers/src/spi",
            "to": "platform/drivers/src/spi"
        },
        {
            "from": "./../../YTM32Bx_SDK/platform/drivers/inc/spi_master_driver.h",
            "to": "platform/drivers/inc/spi_master_driver.h"
        },
        {
            "from": "./../../YTM32Bx_SDK/platform/drivers/inc/spi_slave_driver.h",
            "to": "platform/drivers/inc/spi_slave_driver.h"
        },
        {
            "from": "./../../YTM32Bx_SDK/platform/drivers/inc/spi_shared_function.h",
            "to": "platform/drivers/inc/spi_shared_function.h"
        }
    ],
    "sign": ""
}