{
    "name": "ytlink",
    "type": "driver",
    "srcs": [
        "App.vue",
        "edit.vue",
        "valid.ts",
        "view.ts",
        "mc03def.json",
        "le05def.json",
        "le04def.json",
        "le15def.json",
        "le14def.json",
        "me05def.json",
        "me14def.json",
        "me15def.json",
        "md14def.json",
        "md23def.json",
        "md24def.json",
        "ha01def.json",
        "md04def.json",
        "z1me05def.json",
        "mc03_mcal.json",
        "me05_mcal.json",
        "md14_mcal.json",
        "ha01_mcal.json",
        "md24_mcal.json"
    ],
    "mode": "raw",
    "label": "YT-LINK",
    "headHTML": "<script src='joint.min.js'></script>\r\n<script src='lodash.min.js'></script>",
    "forceEnable": true,
    "generate": [
        {
            "from": "./generate/gcc/gcc.ld",
            "to": "yt_linker.ld",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeGCC') (eq (getProjectInfo 'toolchain') 'Eclipse')}}"
        },
        {
            "from": "./generate/iar/iar.icf",
            "to": "yt_linker.icf",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeEWARM') (eq (getProjectInfo 'toolchain') 'EWARM')}}"
        },
        {
            "from": "./generate/keil/keil.scf",
            "to": "yt_linker.scf",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeKEIL') (eq (getProjectInfo 'toolchain') 'KEIL')}}"
        },
        {
            "from": "./generate/ghs/ghs.ld",
            "to": "yt_linker.ld",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeGHS')}}"
        },
        {
            "from": "./generate/gcc/RamInit0.S",
            "to": "RamInit0.S",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeGCC') (eq (getProjectInfo 'toolchain') 'Eclipse')}}"
        },
        {
            "from": "./generate/iar/RamInit0.S",
            "to": "RamInit0.S",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeEWARM') (eq (getProjectInfo 'toolchain') 'EWARM')}}"
        },
        {
            "from": "./generate/keil/RamInit0.S",
            "to": "RamInit0.S",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeKEIL') (eq (getProjectInfo 'toolchain') 'KEIL')}}"
        },
        {
            "from": "./generate/ghs/RamInit0.s",
            "to": "RamInit0.s",
            "condition": "{{or (eq (getProjectInfo 'toolchain') 'CMakeGHS')}}"
        },
        {
            "from": "./generate/RamInit1_SDK.c",
            "to": "RamInit1.c",
            "condition": "{{or (eq (getProjectInfo 'type') 'sdk')}}"
        },
        {
            "from": "./generate/RamInit1_MCAL.c",
            "to": "RamInit1.c",
            "condition": "{{or (eq (getProjectInfo 'type') 'mcal')}}"
        },
        {
            "from": "./generate/RamInit2_SDK.c",
            "to": "RamInit2.c",
            "condition": "{{or (eq (getProjectInfo 'type') 'sdk')}}"
        },
        {
            "from": "./generate/RamInit2_MCAL.c",
            "to": "RamInit2.c",
            "condition": "{{or (eq (getProjectInfo 'type') 'mcal')}}"
        }
    ],
    "sign": ""
}